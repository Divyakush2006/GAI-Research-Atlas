# Research Atlas Backend Configuration
# Copy this file to .env and fill in your values

# GitHub API token (required for production — without it, rate limit is 60 req/hr)
# Create a token at https://github.com/settings/tokens
GITHUB_TOKEN=

# OpenAlex API email (optional — polite usage, improves rate limits)
OPENALEX_EMAIL=

# OpenAlex User-Agent (optional — identifies your app to the API)
OPENALEX_USER_AGENT=ResearchAtlas/1.0
